# Cortex — copy to `.env` and fill locally. Never commit real secrets.

# Ingest API
PORT=8787
CORTEX_INGEST_TOKEN=local-dev-token

# Collector → API
CORTEX_INGEST_URL=http://localhost:8787
CORTEX_COLLECTOR_INTERVAL_MS=60000

# Remote MCP (Phase 6) — streamable HTTP; see docs/mcp.md
# MCP_PORT=8790
# Prefer a dedicated token; falls back to CORTEX_INGEST_TOKEN if unset
# CORTEX_MCP_TOKEN=local-dev-token
# Optional owner uuid for vault rows + MCP filters (defaults to
# 00000000-0000-4000-8000-000000000001 when unset)
# CORTEX_OWNER_ID=

# Distillates + embeddings (OpenAI-compatible HTTP)
# OPENAI_API_KEY=
# Optional gateway / proxy base (default https://api.openai.com/v1)
# OPENAI_BASE_URL=
# CORTEX_DISTILLATE_MODEL=gpt-4o-mini
# CORTEX_EMBEDDING_MODEL=text-embedding-3-small

# Supabase (EU project) — from Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: local Supabase CLI
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY= (from `supabase status`)
# SUPABASE_SERVICE_ROLE_KEY= (from `supabase status`)

# GitHub work-history (Phase 4) — fine-grained PAT; see docs/github.md
GITHUB_TOKEN=
# Webhook HMAC secret for POST /v1/webhooks/github (optional in local stub)
GITHUB_WEBHOOK_SECRET=
# Optional GitHub Enterprise API base
# GITHUB_API_BASE=https://github.example.com/api/v3

# Google Workspace (Phase 5) — personal Google out of scope for Calendar/Drive/Gmail
# Testing-mode OAuth client; gmail.readonly is restricted (stay in testing).
# Docs: docs/google.md
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# Personal YouTube (recommended when Workspace OAuth is Internal / org-only):
# GOOGLE_YOUTUBE_CLIENT_ID=       # External consent client; falls back to GOOGLE_CLIENT_ID
# GOOGLE_YOUTUBE_CLIENT_SECRET=   # falls back to GOOGLE_CLIENT_SECRET
# GOOGLE_YOUTUBE_REFRESH_TOKEN=   # personal Gmail YouTube; keeps Workspace token above
# GOOGLE_REDIRECT_URI=http://127.0.0.1:8765/oauth2callback
# GOOGLE_ACCOUNT_EMAIL=you@your-workspace.com
# GOOGLE_MOCK=1
# YouTube Data API: enable in GCP; consent with personal External client:
#   pnpm --filter @cortex/google-auth oauth -- --bundle=youtube --login_hint=you@gmail.com
# or --bundle=allWithYoutube (store result as GOOGLE_YOUTUBE_REFRESH_TOKEN)

# Spotify Web API (Phase 5b) — official OAuth only; no scraping
# Docs: docs/sources.md / docs/spotify-youtube.md
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REFRESH_TOKEN=
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8766/callback
# SPOTIFY_MOCK=1
