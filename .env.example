# Cortex — copy to `.env` and fill locally. Never commit real secrets.

# Ingest API
PORT=8787
CORTEX_INGEST_TOKEN=local-dev-token

# Collector → API
CORTEX_INGEST_URL=http://localhost:8787
CORTEX_COLLECTOR_INTERVAL_MS=60000

# Remote MCP (Phase 6) — streamable HTTP; see docs/mcp.md
# MCP_PORT=8790
# Prefer a dedicated token; falls back to CORTEX_INGEST_TOKEN if unset
# CORTEX_MCP_TOKEN=local-dev-token
# Ops endpoint (/mcp/ops) — vault tools + restricted capabilities.
# Falls back to CORTEX_MCP_TOKEN if unset; set separately in production.
# CORTEX_OPS_MCP_TOKEN=local-ops-token
# Optional owner uuid for vault rows + MCP filters (defaults to
# 00000000-0000-4000-8000-000000000001 when unset)
# CORTEX_OWNER_ID=
# Optional Mirror-scoped Supabase key (no raw table SELECT). When unset,
# MCP still uses SERVICE_ROLE server-side but Mirror tools refuse raw vault APIs.
# A "true Mirror role" is a separate Supabase DB role/key that can only SELECT
# distillates + sanitised views + broker RPCs — not records/messages/Storage.
# Create that role in the Dashboard, put its JWT here, then wire Mirror handlers
# to it (see docs/mirror-privilege-plan.md § Credentials).
# SUPABASE_MIRROR_KEY=

# Local OpenAI → Mirror MCP client (@cortex/openai-mirror)
# CORTEX_MIRROR_MCP_URL=http://localhost:8790/mcp
# CORTEX_MCP_MODE=local
# For hosted mode (OpenAI Responses calls Railway):
# CORTEX_MIRROR_MCP_URL=https://cortexmcp-server-production-1c59.up.railway.app/mcp
# CORTEX_MCP_MODE=hosted

# Post-gate source distillates in twin-pipeline.
# Default (when unset): email-thread,github-outcome,calendar-event,drive-file,browser-interest,spotify-interest
# CORTEX_SOURCE_ADAPTERS=email-thread,github-outcome
# CORTEX_SOURCE_ADAPTERS=none
# Drive sensitivity (optional overrides):
# CORTEX_DRIVE_SENSITIVE_PATHS=password,credentials,secrets,private,tax,passport,bank,ssn,identity,2fa,recovery codes
# CORTEX_DRIVE_DISTILL_ALLOW=

# Distillates + embeddings (OpenAI-compatible HTTP)
# Local CLI uses repo .env. Railway MCP must have the same vars (not only local .env).
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# CORTEX_DISTILLATE_MODEL=deepseek/deepseek-v4-flash
# CORTEX_EMBEDDING_MODEL=openai/text-embedding-3-small
# OpenRouter distillate defaults in code: Morph only, ZDR on, data_collection deny
# CORTEX_LLM_PROVIDER_ONLY=Morph
# CORTEX_LLM_ALLOW_FALLBACKS=0
# CORTEX_LLM_ZDR=1
# CORTEX_LLM_DATA_COLLECTION=deny
# CORTEX_LLM_QUANTIZATIONS=bf16,fp16

# Supabase (EU project) — from Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: local Supabase CLI
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY= (from `supabase status`)
# SUPABASE_SERVICE_ROLE_KEY= (from `supabase status`)

# GitHub work-history (Phase 4) — fine-grained PAT; see docs/github.md
GITHUB_TOKEN=
# Webhook HMAC secret for POST /v1/webhooks/github (optional in local stub)
GITHUB_WEBHOOK_SECRET=
# Optional GitHub Enterprise API base
# GITHUB_API_BASE=https://github.example.com/api/v3

# Google Workspace (Phase 5) — personal Google out of scope for Calendar/Drive/Gmail
# Testing-mode OAuth client; gmail.readonly is restricted (stay in testing).
# Docs: docs/google.md
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# Personal YouTube (recommended when Workspace OAuth is Internal / org-only):
# GOOGLE_YOUTUBE_CLIENT_ID=       # External consent client; falls back to GOOGLE_CLIENT_ID
# GOOGLE_YOUTUBE_CLIENT_SECRET=   # falls back to GOOGLE_CLIENT_SECRET
# GOOGLE_YOUTUBE_REFRESH_TOKEN=   # personal Gmail YouTube; keeps Workspace token above
# GOOGLE_REDIRECT_URI=http://127.0.0.1:8765/oauth2callback
# GOOGLE_ACCOUNT_EMAIL=you@your-workspace.com
# GOOGLE_MOCK=1
# YouTube Data API: enable in GCP; consent with personal External client:
#   pnpm --filter @cortex/google-auth oauth -- --bundle=youtube --login_hint=you@gmail.com
# or --bundle=allWithYoutube (store result as GOOGLE_YOUTUBE_REFRESH_TOKEN)

# Spotify Web API (Phase 5b) — official OAuth only; no scraping
# Docs: docs/sources.md / docs/spotify-youtube.md
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REFRESH_TOKEN=
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8766/callback
# SPOTIFY_MOCK=1
