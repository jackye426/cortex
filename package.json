{
  "name": "cortex",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Cortex — personal AI/session vault, canonical store, and remote MCP",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=25"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev:api": "pnpm --filter @cortex/api dev",
    "dev:mcp": "pnpm --filter @cortex/mcp-server dev",
    "dev:collector": "pnpm --filter @cortex/collector dev",
    "backfill": "pnpm --filter @cortex/collector backfill",
    "backfill:dry": "pnpm --filter @cortex/collector backfill:dry",
    "distillate": "pnpm --filter @cortex/mcp-server distillate",
    "embed-backfill": "pnpm --filter @cortex/mcp-server embed-backfill",
    "twin-pipeline": "pnpm --filter @cortex/mcp-server twin-pipeline",
    "youtube-digest": "pnpm --filter @cortex/mcp-server youtube-digest",
    "source-adapter": "pnpm --filter @cortex/mcp-server source-adapter",
    "quality-gate": "pnpm --filter @cortex/mcp-server quality-gate",
    "intrapersonal-metrics": "pnpm --filter @cortex/mcp-server intrapersonal-metrics",
    "test:mcp": "pnpm --filter @cortex/mcp-server test",
    "mirror": "pnpm --filter @cortex/openai-mirror start",
    "mirror:tools": "pnpm --filter @cortex/openai-mirror tools",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "lint": "eslint .",
    "typecheck": "pnpm -r run typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.10",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  }
}
