{
  "name": "@cortex/mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cortex remote MCP server (streamable HTTP + bearer auth)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "pnpm --filter @cortex/mcp-server^... run build && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "distillate": "tsx src/distillate-cli.ts",
    "embed-backfill": "tsx src/embed-backfill-cli.ts",
    "twin-pipeline": "tsx src/twin-pipeline-cli.ts"
  },
  "dependencies": {
    "@cortex/core": "workspace:*",
    "@hono/node-server": "^1.14.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.110.2",
    "hono": "^4.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
